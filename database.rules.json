{
  "rules": {
    "lyrical": {
      "books": {
        "$bookId": {
          ".read": "auth != null",
          // Any authenticated user (publisher or an author whose Google email
          // matches a book's authorEmail — enforced in the app) can write
          // book data. This grants authors FULL access to the consignment
          // tab (stores + ledger live inside the per-book blob in RTDB).
          ".write": "auth != null"
        }
      },
      "submissions": {
        "$bookId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email === 'lyricalmyricalbooks@gmail.com'"
      }
    }
  }
}
