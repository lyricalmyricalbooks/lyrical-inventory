{
  "rules": {
    "lyrical": {
      "books": {
        "$bookId": {
          ".read": "auth != null",
          // Publisher writes any book; an author writes ONLY the book whose
          // authorEmail matches theirs in settings/bookOwners (a plain map
          // maintained by the publisher client). Ownership lives there because
          // the per-book payload is a stringified JSON string these rules can't
          // introspect. Missing map/entry → not the owner → denied.
          ".write": "auth != null && (auth.token.email === 'lyricalmyricalbooks@gmail.com' || root.child('lyrical/settings/bookOwners').child($bookId).val() === auth.token.email.toLowerCase())",
          // Shape guard: the app always writes the whole node as
          // { data: <json string>, ts: <number> }. Reject anything else and cap
          // the blob at ~5 MB so a buggy or malicious client can't bloat the DB
          // (deletes set null and skip validation, so this doesn't block them).
          ".validate": "newData.hasChildren(['data','ts']) && newData.child('data').isString() && newData.child('data').val().length < 5000000 && newData.child('ts').isNumber()"
        }
      },
      "submissions": {
        "$bookId": {
          // Publisher sees/writes every book's submissions; an author may only
          // read and write submissions for their own book.
          ".read": "auth != null && (auth.token.email === 'lyricalmyricalbooks@gmail.com' || root.child('lyrical/settings/bookOwners').child($bookId).val() === auth.token.email.toLowerCase())",
          ".write": "auth != null && (auth.token.email === 'lyricalmyricalbooks@gmail.com' || root.child('lyrical/settings/bookOwners').child($bookId).val() === auth.token.email.toLowerCase())"
        }
      },
      "settings": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email === 'lyricalmyricalbooks@gmail.com'"
      },
      "backups": {
        // System backup snapshots — one node per backup, publisher only.
        ".read": "auth != null && auth.token.email === 'lyricalmyricalbooks@gmail.com'",
        ".write": "auth != null && auth.token.email === 'lyricalmyricalbooks@gmail.com'"
      }
    }
  }
}
