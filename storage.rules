rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /receipts/{allPaths=**} {
      // Authors and the publisher both upload receipt images/PDFs, so any
      // authenticated user may read and write here. Writes are constrained to
      // reasonably sized images/PDFs to stop the bucket being used as free
      // file storage or filled with junk that runs up egress/storage costs.
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if request.auth != null;
    }
  }
}
