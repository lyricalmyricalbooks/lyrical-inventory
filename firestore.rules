rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Per-book data — only authenticated users can read; only publisher can write
    match /books/{bookId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'lyricalmyricalbooks@gmail.com';
      
      // Sub-collection documents for sliced state (ledger, expenses, hist, etc.)
      match /data/{part} {
        allow read: if request.auth != null;
        // Publisher can write any part. Authors are granted FULL write access
        // to consignment-related parts (stores + ledger) so they can manage
        // consignment accounts and the consignment ledger directly.
        allow write: if request.auth != null &&
          (request.auth.token.email == 'lyricalmyricalbooks@gmail.com'
            || part == 'stores'
            || part == 'ledger');
      }
    }
    
    // Author submissions — any authenticated user can read and write
    // (authors write their own; publisher reads all)
    match /submissions/{bookId}/{type}/{subId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Global settings — catalog, taxCenter, productionCosts, paymentLinks, systemBackups
    // Only the publisher account can write these
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'lyricalmyricalbooks@gmail.com';
    }
  }
}
