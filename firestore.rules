rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Publisher account — full read/write everywhere.
    function isPublisher() {
      return request.auth != null
        && request.auth.token.email == 'lyricalmyricalbooks@gmail.com';
    }

    // Author→book ownership comes from the rules-readable map at
    // settings/bookOwners ({ bookId: authorEmailLower }), maintained by the
    // publisher client. The catalog itself is a stringified blob these rules
    // can't parse, hence this companion map. A missing map or entry means the
    // caller is not an author for that book, so write is denied.
    function bookOwnerEmail(bookId) {
      return exists(/databases/$(database)/documents/settings/bookOwners)
        ? get(/databases/$(database)/documents/settings/bookOwners).data.get(bookId, '')
        : '';
    }
    function isBookAuthor(bookId) {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == bookOwnerEmail(bookId);
    }

    // Per-book data — any authenticated user can read. Publisher writes any
    // part; the owning author may write ONLY the consignment parts (stores +
    // ledger) of their own book.
    match /books/{bookId} {
      allow read: if request.auth != null;
      allow write: if isPublisher();

      match /data/{part} {
        allow read: if request.auth != null;
        allow write: if isPublisher()
          || ((part == 'stores' || part == 'ledger') && isBookAuthor(bookId));
      }
    }

    // Author submissions — publisher reads/writes all; an author may only read
    // and write submissions for their own book.
    match /submissions/{bookId}/{type}/{subId} {
      allow read, write: if isPublisher() || isBookAuthor(bookId);
    }

    // Global settings — catalog, taxCenter, productionCosts, paymentLinks,
    // bookOwners, systemBackups, modeFlags. Readable by any authenticated user;
    // only the publisher can write.
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if isPublisher();
    }

    // Email receipt inbox — draft expenses pushed by the Gmail add-on.
    // The add-on writes via the owner's OAuth token (IAM, which bypasses these
    // rules); the publisher client reads them live and deletes each one after
    // importing it into the tax centre.
    match /emailReceiptInbox/{document} {
      allow read, write: if isPublisher();
    }
  }
}
